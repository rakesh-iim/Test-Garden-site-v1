{
  "entities": {
    "ContactSubmission": {
      "title": "Contact Submission",
      "description": "A request for a visit or quote from a potential client.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the client" },
        "email": { "type": "string", "description": "Email of the client" },
        "phone": { "type": "string", "description": "Phone number" },
        "message": { "type": "string", "description": "Additional details or message" },
        "createdAt": { "type": "string", "description": "Timestamp of submission" }
      },
      "required": ["name", "email", "createdAt"]
    },
    "Resource": {
      "title": "Resource",
      "description": "A portfolio resource, image, or gallery item publicly visible.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "category": { "type": "string" },
        "img": { "type": "string", "description": "URL to the image" },
        "createdAt": { "type": "string" }
      },
      "required": ["title", "img", "createdAt"]
    }
  },
  "firestore": {
    "/contact_submissions/{submissionId}": {
      "schema": "ContactSubmission",
      "description": "User queries for booking visits"
    },
    "/resources/{resourceId}": {
      "schema": "Resource",
      "description": "Public portfolio items and gallery resources"
    }
  }
}
